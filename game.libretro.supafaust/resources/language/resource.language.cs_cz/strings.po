msgctxt "Addon Summary"
msgid "Nintendo - SNES / SFC (Beetle Supafaust)"
msgstr "Nintendo - SNES / SFC (Beetle Supafaust)"

msgctxt "Addon Description"
msgid "Supafaust is a SNES emulator for multicore ARM Linux platforms. It is particularly suitable for low-end devices."
msgstr "Supafaust je emulátor SNES pro vícejádrové platformy ARM Linux. Je zvlášť vhodný pro méně výkonná zařízení."

msgctxt "#30001"
msgid "Pixel format"
msgstr "Formát pixelů"

msgctxt "#30002"
msgid "Correct pixel aspect ratio"
msgstr "Opravit poměr stran pixelů"

msgctxt "#30003"
msgid "Horizontal blend/double filter"
msgstr "Filtr horizontálního prolnutí/zdvojení"

msgctxt "#30004"
msgid "Deinterlacer"
msgstr "Odstraňování prokladu"

msgctxt "#30005"
msgid "First displayed scanline in NTSC mode"
msgstr "První zobrazený skenovací řádek v režimu NTSC"

msgctxt "#30006"
msgid "Last displayed scanline in NTSC mode"
msgstr "Poslední zobrazený skenovací řádek v režimu NTSC"

msgctxt "#30007"
msgid "First displayed scanline in PAL mode"
msgstr "První zobrazený skenovací řádek v režimu PAL"

msgctxt "#30008"
msgid "Last displayed scanline in PAL mode"
msgstr "Poslední zobrazený skenovací řádek v režimu PAL"

msgctxt "#30009"
msgid "Region/Type of SNES to emulate"
msgstr "Region/typ emulovaného SNES"

msgctxt "#30010"
msgid "Begin frame in SNES VBlank to lower latency"
msgstr "Zahajovat snímek v intervalu VBlank SNES pro snížení latence"

msgctxt "#30011"
msgid "Enable 1-frame run-ahead"
msgstr "Povolit run-ahead o jeden snímek"

msgctxt "#30012"
msgid "Enable multitap"
msgstr "Povolit multitap"

msgctxt "#30013"
msgid "CX4 clock rate %"
msgstr "Taktovací frekvence CX4 %"

msgctxt "#30014"
msgid "SuperFX clock rate %"
msgstr "Taktovací frekvence SuperFX %"

msgctxt "#30015"
msgid "Emulate SuperFX instruction cache"
msgstr "Emulovat mezipaměť instrukcí SuperFX"

msgctxt "#30016"
msgid "Internal resampler(output rate)"
msgstr "Interní resampler (výstupní frekvence)"

msgctxt "#30017"
msgid "Emulation thread affinity mask"
msgstr "Maska afinity emulačního vlákna"

msgctxt "#30018"
msgid "PPU render thread affinity mask"
msgstr "Maska afinity vykreslovacího vlákna PPU"

msgctxt "#30019"
msgid "PPU renderer"
msgstr "Vykreslovač PPU"
