msgctxt "Addon Summary"
msgid "Nintendo - SNES / SFC (Beetle Supafaust)"
msgstr "Nintendo — SNES / SFC (Beetle Supafaust)"

msgctxt "Addon Description"
msgid "Supafaust is a SNES emulator for multicore ARM Linux platforms. It is particularly suitable for low-end devices."
msgstr "Supafaust — это эмулятор SNES для многопроцессорных платформ ARM Linux. Он особенно подходит для маломощных устройств."

msgctxt "#30001"
msgid "Pixel format"
msgstr "Формат пикселей"

msgctxt "#30002"
msgid "Correct pixel aspect ratio"
msgstr "Корректировать соотношение сторон пикселей"

msgctxt "#30003"
msgid "Horizontal blend/double filter"
msgstr "Горизонтальное смешивание/двойной фильтр"

msgctxt "#30004"
msgid "Deinterlacer"
msgstr "Деинтерлейсер"

msgctxt "#30005"
msgid "First displayed scanline in NTSC mode"
msgstr "Первая отображаемая строка развёртки в режиме NTSC"

msgctxt "#30006"
msgid "Last displayed scanline in NTSC mode"
msgstr "Последняя отображаемая строка развёртки в режиме NTSC"

msgctxt "#30007"
msgid "First displayed scanline in PAL mode"
msgstr "Первая отображаемая строка развёртки в режиме PAL"

msgctxt "#30008"
msgid "Last displayed scanline in PAL mode"
msgstr "Последняя отображаемая строка развёртки в режиме PAL"

msgctxt "#30009"
msgid "Region/Type of SNES to emulate"
msgstr "Регион/тип эмулируемой SNES"

msgctxt "#30010"
msgid "Begin frame in SNES VBlank to lower latency"
msgstr "Начинать кадр в VBlank SNES для снижения задержки"

msgctxt "#30011"
msgid "Enable 1-frame run-ahead"
msgstr "Включить упреждение на 1 кадр"

msgctxt "#30012"
msgid "Enable multitap"
msgstr "Включить мультитап"

msgctxt "#30013"
msgid "CX4 clock rate %"
msgstr "Тактовая частота CX4, %"

msgctxt "#30014"
msgid "SuperFX clock rate %"
msgstr "Тактовая частота SuperFX, %"

msgctxt "#30015"
msgid "Emulate SuperFX instruction cache"
msgstr "Эмулировать кэш команд SuperFX"

msgctxt "#30016"
msgid "Internal resampler(output rate)"
msgstr "Внутренний ресемплер (выходная частота)"

msgctxt "#30017"
msgid "Emulation thread affinity mask"
msgstr "Маска привязки потока эмуляции"

msgctxt "#30018"
msgid "PPU render thread affinity mask"
msgstr "Маска привязки потока отрисовки PPU"

msgctxt "#30019"
msgid "PPU renderer"
msgstr "Отрисовщик PPU"

#~ msgctxt "#30000"
#~ msgid "Settings"
#~ msgstr "Настройки"
